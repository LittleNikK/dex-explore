generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pool {
  id        String   @id
  token0    String
  token1    String
  feeTier   Int
  liquidity String
  tvlUSD    Float
  volumeUSD Float
  createdAt DateTime
}

model Swap {
  id        String   @id
  poolId    String
  sender    String
  recipient String
  amount0   String
  amount1   String
  txHash    String
  timestamp DateTime
}

model OHLCV {
  id        String   @id
  poolId    String
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  timestamp DateTime
}
